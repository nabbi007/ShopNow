# ShopNow — environment configuration (template)
# Copy to .env and adjust as needed:  cp .env.example .env
# docker-compose reads .env automatically from the project root.

# --- Postgres ---
POSTGRES_USER=shopnow
POSTGRES_PASSWORD=shopnow123
POSTGRES_DB=shopnow

# --- Backend ---
# Note: hosts (db, redis, backend) are docker-compose service names.
DATABASE_URL=postgresql+asyncpg://shopnow:shopnow123@db:5432/shopnow
REDIS_URL=redis://redis:6379
SECRET_KEY=dev-secret-key-change-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:3003","http://localhost:80","http://frontend"]

# --- Frontend ---
BACKEND_HOST=backend:8000
